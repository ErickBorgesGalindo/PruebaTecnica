    {
      "name": "Bitácora",
      "item": [
        {
          "name": "Listar registros de bitácora",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"]
            },
            "description": "Retorna el historial de cambios paginado. Parámetros opcionales: entity_type (product/user/profile), action (created/updated/deleted)."
          }
        },
        {
          "name": "Filtrar por entidad",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit-logs?entity_type=product",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                { "key": "entity_type", "value": "product", "description": "product, user o profile" }
              ]
            },
            "description": "Filtra la bitácora por tipo de entidad."
          }
        },
        {
          "name": "Filtrar por acción",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit-logs?action=updated",
              "host": ["{{baseUrl}}"],
              "path": ["audit-logs"],
              "query": [
                { "key": "action", "value": "updated", "description": "created, updated o deleted" }
              ]
            },
            "description": "Filtra la bitácora por tipo de acción."
          }
        }
      ]
    }
