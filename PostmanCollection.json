{
  "info": {
    "name": "TAP Terminal - API",
    "description": "API REST del sistema de gestión de TAP Terminal.\n\n## Instrucciones de uso\n1. Ejecuta `POST /auth/login` con las credenciales para obtener el token.\n2. Copia el token y guárdalo en la variable de entorno `token`.\n3. Todas las demás peticiones autorizadas usarán este token automáticamente.\n\n## Credenciales de prueba\n- **Admin:** admin@test.com / password123 (acceso total)\n- **Solo lectura:** maria@test.com / password123 (solo productos)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Inicia sesión y retorna el token JWT, el usuario y sus perfiles/secciones."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Cierra la sesión e invalida el token actual."
          }
        },
        {
          "name": "Obtener usuario actual",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Retorna el usuario autenticado con sus perfiles y secciones."
          }
        },
        {
          "name": "Recuperar contraseña",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Genera una contraseña temporal y la retorna. En producción se enviaría por email."
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Retorna todos los productos."
          }
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Dell\",\n  \"brand\": \"Dell\",\n  \"price\": 18999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            },
            "description": "Crea un nuevo producto. El código se genera automáticamente. Campos requeridos: name, brand, price (máx 999)."
          }
        },
        {
          "name": "Obtener producto",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{id}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{id}"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Retorna un producto por su ID."
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Dell XPS\",\n  \"brand\": \"Dell\",\n  \"price\": 21999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{id}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{id}"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Actualiza un producto existente. Solo envía los campos que quieras cambiar."
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{id}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{id}"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Elimina un producto por su ID."
          }
        },
        {
          "name": "Exportar productos PDF",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/export/products/pdf",
              "host": ["{{baseUrl}}"],
              "path": ["export", "products", "pdf"]
            },
            "description": "Descarga el listado de productos en formato PDF."
          }
        },
        {
          "name": "Exportar productos Excel",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/export/products/excel",
              "host": ["{{baseUrl}}"],
              "path": ["export", "products", "excel"]
            },
            "description": "Descarga el listado de productos en formato Excel (.xlsx)."
          }
        }
      ]
    },
